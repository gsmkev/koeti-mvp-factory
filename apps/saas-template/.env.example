POSTGRES_URL=postgresql://saas_template:localdev@localhost:5432/saas_template
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Pagopar (pagopar.com.py) — Stripe alternative for Paraguay. Keys from
# "Integrar con mi sitio web" in the Pagopar dashboard; set the webhook
# ("respuesta") URL there to <BASE_URL>/api/pagopar/webhook. Optional — used
# only when STRIPE_SECRET_KEY is empty; without either, /pricing shows the
# static catalog and checkout is a no-op.
PAGOPAR_PUBLIC_TOKEN=
PAGOPAR_PRIVATE_TOKEN=
# Plan catalog (Pagopar has no product API): Name:guaraníes-per-month pairs
PAGOPAR_PLANS=Base:60000,Plus:90000
BASE_URL=http://localhost:3000
AUTH_SECRET=
RESEND_API_KEY=
EMAIL_FROM=staff@koeti.com.py
# Google sign-in (optional): OAuth client from console.cloud.google.com →
# APIs & Services → Credentials. Redirect URI: <BASE_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Analytics backend: posthog | vercel | none (default: posthog if key set, else none)
NEXT_PUBLIC_ANALYTICS_PROVIDER=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
SUPERADMIN_EMAIL=

# Dev-only: extra hostnames allowed to fetch /_next/* assets (SSH/host-forwarded dev). Comma-separated.
DEV_ORIGINS=

# AI layer (@koeti/ai): API key from console.mistral.ai. Optional — AI features
# fail gracefully without it; the insights cron is statistical and never needs it.
MISTRAL_API_KEY=
# File uploads (@koeti/storage): Vercel Blob token (Storage tab of the Vercel
# project). Optional — without it uploads land on local disk (.uploads/, dev only).
BLOB_READ_WRITE_TOKEN=
# Shared secret for cron routes. Vercel sends it as Authorization: Bearer <secret>.
CRON_SECRET=
